{
  "name": "chedaroo/inertia-marko",
  "type": "marko-module",
  "description": "The Marko adapter for Inertia.js.",
  "keywords": [
    "marko",
    "inertia"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Richard Jesudason",
      "email": "richard@jesudason.co.uk",
      "homepage": "https://jesudason.co.uk"
    }
  ],
  "autoload": {
    "psr-4": {
      "Inertia\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.5",
    "marko/routing": "*",
    "marko/view": "^0.1.0"
  },
  "require-dev": {
    "pestphp/pest": "^4.4"
  },
  "extra": {
    "marko": {
      "module": true
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
